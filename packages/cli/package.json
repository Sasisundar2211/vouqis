{
  "name": "@vouqis/cli",
  "version": "0.1.4",
  "description": "The trust layer for MCP servers. Score, trace, and replay your AI agent tool calls.",
  "type": "module",
  "author": "Sundar Sasi",
  "license": "MIT",
  "homepage": "https://github.com/Sasisundar2211/vouqis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sasisundar2211/vouqis.git"
  },
  "bin": {
    "vouqis": "bin/run.js"
  },
  "files": [
    "bin",
    "dist"
